# terraform/environments/prod/terraform.tfvars.example
# Copy to terraform.tfvars and fill in values

aws_region             = "ap-south-1"
environment            = "prod"
project                = "ivr"
alert_email            = "swanand.awatade@gmail.com"
connect_inbound_number = "+911234567890"
crm_api_endpoint       = "https://crm.example.com/api/v1"
lambda_log_level       = "INFO"
dynamodb_billing_mode  = "PAY_PER_REQUEST"
enable_connect_recording = true
callback_retention_days  = 86400
